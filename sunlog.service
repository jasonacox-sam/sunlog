[Unit]
Description=sunlog — Solar + Powerwall Energy Diary
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
User=jason
WorkingDirectory=/home/jason/.openclaw/workspace/sunlog
ExecStart=/usr/bin/python3 /home/jason/.openclaw/workspace/sunlog/sunlog.py
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sunlog

[Install]
WantedBy=multi-user.target
